{
  "Mongo": {
    "DatabaseUri": "mongodb://set-automatically-when-deployed/admin?authSource=$external&authMechanism=MONGODB-AWS",
    "DatabaseName": "waste-obligations"
  },
  "AllowedHosts": "*",
  "TraceHeader": "x-cdp-request-id",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console",
              "Args": {
                "formatter": "Elastic.CommonSchema.Serilog.EcsTextFormatter, Elastic.CommonSchema.Serilog"
              }
            }
          ]
        }
      }
    ]
  },
  "Acl": {
    "Comment": "See CDP secrets for ApiKey clients and CDP App Config for OAuth client per environment",
    "Clients": {}
  },
  "PrnCommonBackend": {
    "TokenEndpoint": "http://localhost:9090/oauth2/v2.0/token",
    "ClientId": "client_id",
    "ClientSecret": "client_secret",
    "Scope": "scope",
    "BaseAddress": "http://localhost:9090/"
  },
  "AccountBackend": {
    "TokenEndpoint": "http://localhost:9090/oauth2/v2.0/token",
    "ClientId": "client_id",
    "ClientSecret": "client_secret",
    "Scope": "scope",
    "BaseAddress": "http://localhost:9090/"
  },
  "WasteOrganisations": {
    "ClientId": "client_id",
    "ClientSecret": "client_secret",
    "BaseAddress": "http://localhost:9090/"
  },
  "GovukNotify": {
    "ApiKey": "api_key",
    "Templates": {
      "ComplianceDeclarationSubmissionDirectProducer": {
        "TemplateId": {
          "En": "5f64e3bd-d454-4a45-a9c6-9409bf940d7a",
          "Cy": "b3223b0b-a467-40c1-9150-f78b76d11fd8"
        }
      }
    }
  },
  "AnalyticsAuditEventProcessor": {
    "ProcessingEnabled": false,
    "ProcessName": "analytics",
    "TopicArn": "set-automatically-when-deployed",
    "BatchSize": 25,
    "PollIntervalSeconds": 15,
    "PollJitterSeconds": 5,
    "LeaseDurationSeconds": 60,
    "MaxDispatchAttempts": 5,
    "FailedDispatchRetryDelaySeconds": 60
  },
  "AnalyticsAuditEventConsumer": {
    "ProcessingEnabled": false,
    "QueueUrl": "set-automatically-when-deployed",
    "BatchSize": 10,
    "WaitTimeSeconds": 20,
    "PollIntervalSeconds": 15
  }
}
